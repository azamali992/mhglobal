# =============================================================================
# MH Global Attire — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must never be committed.
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon (recommended): https://console.neon.tech/
#   Project → Connection Details → Pooled connection string (includes ?sslmode=require)
# Supabase: Project Settings → Database → Connection string → URI
# Railway: Postgres service → Variables tab → DATABASE_URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Gmail SMTP (Nodemailer) ──────────────────────────────────────────────────
# GMAIL_USER: the full Gmail address that sends inquiry notification emails.
# GMAIL_APP_PASSWORD: a 16-character App Password — NOT your normal password.
#   Requires 2-Step Verification to be enabled on the account first:
#   1. Enable 2-Step Verification: https://myaccount.google.com/signinoptions/two-step-verification
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#      (Select app: "Mail" / device: "Other" → name it anything)
# Note: Email dispatch is wired in Phase 4. Phase 1 builds the transporter only.
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── Admin CMS seed credentials ───────────────────────────────────────────────
# These become the first /admin/login credentials after running: npx tsx content/seed.ts
# The seed script bcrypt-hashes ADMIN_PASSWORD before storing it — never stored as plaintext.
# Change the password after first login.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-on-first-login"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# NEXTAUTH_SECRET: a random 32+ byte string used to sign and encrypt JWT session tokens.
#   Generate one: openssl rand -base64 32
# NEXTAUTH_URL: the canonical URL of the deployment. Must be set in production.
NEXTAUTH_SECRET="replace-with-32-byte-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Used for image uploads (categories, products, inquiries, certifications).
# Wired in Phase 3. Safe to leave blank locally until then.
# Account: https://cloudinary.com/users/register/free
# Dashboard → API Keys → Cloud name, API Key, API Secret
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Cloudflare Turnstile (spam protection on the inquiry form) ───────────────
# Optional — inquiry form works without it (honeypot + rate-limit still apply).
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ─── Site URL (SEO: canonical tags, sitemap, OG image URLs) ──────────────────
# Leave unset in dev (defaults to http://localhost:3000). Set to the real
# production domain once deployed, e.g. "https://www.mhglobalattire.com"
NEXT_PUBLIC_SITE_URL=""

# ─── Analytics & Search Console (optional, add at/near launch) ───────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
GOOGLE_SITE_VERIFICATION=""
